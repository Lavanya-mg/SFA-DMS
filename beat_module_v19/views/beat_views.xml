<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Beat Module Form View — Odoo 19 Enterprise -->
    <record id="view_beat_module_form" model="ir.ui.view">
        <field name="name">beat.module.form</field>
        <field name="model">beat.module</field>
        <field name="arch" type="xml">
            <form string="Beat">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,pending,in_progress,completed,swapped"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="beat_number" readonly="1" class="oe_inline"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name" placeholder="e.g. Downtown Route, Zone A…"/>
                            <field name="employee_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="beat_date"/>
                            <field name="allowed_days" widget="selection"/>
                        </group>
                        <group>
                            <field name="customer_count" readonly="1"/>
                            <field name="swap_reason" invisible="status != 'swapped'"/>
                            <field name="swapped_date" invisible="status != 'swapped'" readonly="1"/>
                            <field name="swapped_to_beat_id" invisible="status != 'swapped'" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Customers" name="customers">
                            <field name="beat_line_ids" widget="one2many">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="partner_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="partner_phone" readonly="1" optional="show"/>
                                    <field name="partner_email" readonly="1" optional="show"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                                <form string="Beat Line">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="beat_id" invisible="1"/>
                                                <field name="partner_id" options="{'no_create': True}"/>
                                                <field name="sequence"/>
                                            </group>
                                            <group>
                                                <field name="partner_phone" readonly="1"/>
                                                <field name="partner_email" readonly="1"/>
                                            </group>
                                        </group>
                                        <field name="notes" placeholder="Additional notes about this customer visit…"/>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Beat Module List View -->
    <record id="view_beat_module_list" model="ir.ui.view">
        <field name="name">beat.module.list</field>
        <field name="model">beat.module</field>
        <field name="arch" type="xml">
            <list string="Beats"
                  decoration-success="status == 'completed'"
                  decoration-warning="status == 'in_progress'"
                  decoration-info="status == 'pending'"
                  decoration-muted="status == 'swapped'">
                <field name="beat_number"/>
                <field name="name"/>
                <field name="beat_date"/>
                <field name="employee_id"/>
                <field name="customer_count"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'completed'"
                       decoration-warning="status == 'in_progress'"
                       decoration-info="status == 'pending'"
                       decoration-danger="status == 'swapped'"/>
            </list>
        </field>
    </record>

    <!-- Beat Module Kanban View -->
    <record id="view_beat_module_kanban" model="ir.ui.view">
        <field name="name">beat.module.kanban</field>
        <field name="model">beat.module</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" group_by="status">
                <field name="id"/>
                <field name="beat_number"/>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="customer_count"/>
                <field name="status"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="beat_number"/>
                                    </strong>
                                    <br/>
                                    <span class="o_kanban_record_subtitle">
                                        <field name="name"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="employee_id"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span class="badge rounded-pill text-bg-primary">
                                        <i class="fa fa-users"/> <field name="customer_count"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Beat Module Search View -->
    <record id="view_beat_module_search" model="ir.ui.view">
        <field name="name">beat.module.search</field>
        <field name="model">beat.module</field>
        <field name="arch" type="xml">
            <search string="Search Beats">
                <field name="beat_number"/>
                <field name="name"/>
                <field name="employee_id"/>
                <separator/>
                <filter string="My Beats" name="my_beats"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="Today" name="today"
                        domain="[('beat_date', '=', context_today())]"/>
                <filter string="In Progress" name="in_progress"
                        domain="[('status', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed"
                        domain="[('status', '=', 'completed')]"/>
                <separator/>
                <group>
                    <filter string="Employee" name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Status" name="group_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'beat_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Beat Module Calendar View -->
    <record id="view_beat_module_calendar" model="ir.ui.view">
        <field name="name">beat.module.calendar.view</field>
        <field name="model">beat.module</field>
        <field name="arch" type="xml">
            <calendar string="Beats" date_start="beat_date" mode="month"
                      quick_create="0" color="employee_id">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="customer_count"/>
            </calendar>
        </field>
    </record>

    <!-- Beat Module Action -->
    <record id="action_beat_module" model="ir.actions.act_window">
        <field name="name">Beats</field>
        <field name="res_model">beat.module</field>
        <field name="view_mode">list,kanban,calendar,form</field>
        <field name="search_view_id" ref="view_beat_module_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Beat</p>
            <p>
                Beats help you organize customer visits by routes.<br/>
                Assign employees and map customers to each beat.
            </p>
        </field>
    </record>

    <!-- Partner form — Beat Assignments tab -->
    <record id="view_partner_form_beat" model="ir.ui.view">
        <field name="name">res.partner.form.beat.v19</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Beat Assignments" name="beat_assignments">
                    <field name="beat_line_ids" readonly="1">
                        <list>
                            <field name="beat_id"/>
                            <field name="sequence"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Menu Items (hidden by default — exposed via Employee 360 menu) -->
    <menuitem id="menu_beat_root"
              name="Beat Management"
              active="False"
              sequence="50"/>
    <menuitem id="menu_beat_module"
              name="Beats"
              parent="menu_beat_root"
              action="action_beat_module"
              sequence="10"/>
</odoo>
