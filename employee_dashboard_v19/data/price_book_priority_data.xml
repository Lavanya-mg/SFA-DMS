<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Default priority order — client can reorder via Configuration > Priority Config -->
    <record id="pbp_customer" model="price.book.priority">
        <field name="sequence">10</field>
        <field name="price_type">customer</field>
        <field name="active">True</field>
    </record>
    <record id="pbp_combination" model="price.book.priority">
        <field name="sequence">20</field>
        <field name="price_type">combination</field>
        <field name="active">True</field>
    </record>
    <record id="pbp_category" model="price.book.priority">
        <field name="sequence">30</field>
        <field name="price_type">category</field>
        <field name="active">True</field>
    </record>
    <record id="pbp_territory" model="price.book.priority">
        <field name="sequence">40</field>
        <field name="price_type">territory</field>
        <field name="active">True</field>
    </record>
    <record id="pbp_channel" model="price.book.priority">
        <field name="sequence">50</field>
        <field name="price_type">channel</field>
        <field name="active">True</field>
    </record>
    <record id="pbp_base" model="price.book.priority">
        <field name="sequence">99</field>
        <field name="price_type">base</field>
        <field name="active">True</field>
    </record>
</odoo>
