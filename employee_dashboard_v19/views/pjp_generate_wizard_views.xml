<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pjp_generate_wizard_form" model="ir.ui.view">
        <field name="name">pjp.generate.wizard.form</field>
        <field name="model">pjp.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Journey Plan">
                <sheet>
                    <div class="alert alert-info" role="alert" style="margin-bottom:16px;">
                        <i class="fa fa-info-circle me-2"/>
                        This will create PJP items from existing beat assignments in the selected date range.
                        Beats must already be created for the employee before generating the plan.
                    </div>

                    <group string="Employee &amp; Date Range">
                        <group>
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="pjp_id"
                                   domain="[('employee_id', '=', employee_id), ('state', 'not in', ['completed','cancelled'])]"
                                   options="{'no_create': True}"
                                   help="Leave empty to auto-find or create a PJP"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>

                    <group string="Summary" invisible="not employee_id">
                        <group>
                            <field name="beat_count_in_range" readonly="1"/>
                        </group>
                        <group>
                            <field name="existing_pjp_count" readonly="1"/>
                        </group>
                    </group>

                    <group string="Exclusion Options">
                        <group>
                            <field name="exclude_weekoffs"/>
                            <field name="exclude_holidays"/>
                        </group>
                        <group>
                            <field name="exclude_leaves"/>
                            <field name="is_regenerate"/>
                        </group>
                    </group>

                    <div class="alert alert-warning" role="alert"
                         invisible="not is_regenerate">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Regenerate mode:</strong> Existing draft/approved PJP items in the date range will be deleted and recreated.
                    </div>
                </sheet>
                <footer>
                    <button name="action_generate"
                            type="object"
                            string="Generate Plan"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pjp_generate_wizard" model="ir.actions.act_window">
        <field name="name">Generate Journey Plan</field>
        <field name="res_model">pjp.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
