    <!-- ══════════════════════════════════════════════════════════════════
         PRICE BOOK PRIORITY CONFIG
         ══════════════════════════════════════════════════════════════════ -->

    <record id="view_price_book_priority_list" model="ir.ui.view">
        <field name="name">price.book.priority.list</field>
        <field name="model">price.book.priority</field>
        <field name="arch" type="xml">
            <list string="Priority Configuration" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="price_type"/>
                <field name="description" readonly="1"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_price_book_priority_form" model="ir.ui.view">
        <field name="name">price.book.priority.form</field>
        <field name="model">price.book.priority</field>
        <field name="arch" type="xml">
            <form string="Priority Rule">
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="price_type"/>
                        <field name="description" readonly="1"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_price_book_priority" model="ir.actions.act_window">
        <field name="name">Priority Configuration</field>
        <field name="res_model">price.book.priority</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define priority order for price book types.
                Drag rows to reorder — highest row wins when multiple prices match.
            </p>
        </field>
    </record>

</odoo>
