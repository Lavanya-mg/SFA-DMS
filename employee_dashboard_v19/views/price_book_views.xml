<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         PRICE BOOK
         ══════════════════════════════════════════════════════════════════ -->

    <!-- ── List View ──────────────────────────────────────────────────── -->
    <record id="view_price_book_list" model="ir.ui.view">
        <field name="name">price.book.list</field>
        <field name="model">price.book</field>
        <field name="arch" type="xml">
            <list string="Price Book" decoration-muted="not active">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="price_type"/>
                <field name="product_id"/>
                <field name="customer_id"/>
                <field name="category_id"/>
                <field name="territory"/>
                <field name="channel"/>
                <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="min_qty"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ──────────────────────────────────────────────────── -->
    <record id="view_price_book_form" model="ir.ui.view">
        <field name="name">price.book.form</field>
        <field name="model">price.book</field>
        <field name="arch" type="xml">
            <form string="Price Book Entry">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Amul Milk — Customer Price for Reliance"/></h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="price_type"/>
                            <field name="sequence"/>
                            <field name="active" invisible="1"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Pricing">
                            <field name="unit_price" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="min_qty"/>
                            <field name="uom_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Scope — fill only fields relevant to the price type">
                        <group>
                            <field name="product_tmpl_id"
                                   placeholder="Leave blank to apply to all products"/>
                            <field name="product_id"
                                   domain="[('product_tmpl_id','=',product_tmpl_id)]"
                                   placeholder="Leave blank for all variants"/>
                            <field name="customer_id"
                                   invisible="price_type not in ('customer','combination')"
                                   placeholder="Required for Customer-wise"/>
                            <field name="category_id"
                                   invisible="price_type not in ('category','combination')"
                                   placeholder="Required for Category-wise"/>
                        </group>
                        <group>
                            <field name="territory"
                                   invisible="price_type not in ('territory','combination')"
                                   placeholder="e.g. Bangalore, Kerala"/>
                            <field name="channel"
                                   invisible="price_type not in ('channel','combination')"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

