<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Product Category List View ─────────────────────────────────── -->
    <record id="view_product_category_list_emp360" model="ir.ui.view">
        <field name="name">product.category.list.emp360</field>
        <field name="model">product.category</field>
        <field name="arch" type="xml">
            <list string="Product Categories">
                <field name="complete_name"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <!-- ── Product Category Form View ────────────────────────────────── -->
    <record id="view_product_category_form_emp360" model="ir.ui.view">
        <field name="name">product.category.form.emp360</field>
        <field name="model">product.category</field>
        <field name="arch" type="xml">
            <form string="Product Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Category Name"/>
                        <h1><field name="name" placeholder="e.g. Food, Detergent, FMCG"/></h1>
                    </div>
                    <group>
                        <field name="parent_id" options="{'no_create': False}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

