<odoo>
   <!-- 1. Tree View -->
    <record id="view_sfa_expense_band_tree" model="ir.ui.view">
        <field name="name">sfa.expense.band.list</field>
        <field name="model">sfa.expense.band</field>
        <field name="arch" type="xml">
            <!-- Change <tree> to <list> -->
            <list >
                <field name="band_code"/>
                <field name="band_name"/>
                <field name="grade"/>
                <field name="designation"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_expense_band_form" model="ir.ui.view">
        <field name="name">sfa.expense.band.form</field>
        <field name="model">sfa.expense.band</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="band_code"/>
                            <field name="band_name"/>
                        </group>
                        <group>
                            <field name="grade"/>
                            <field name="designation"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 2. Action linking to the above view -->
    <record id="action_sfa_expense_band" model="ir.actions.act_window">
        <field name="name">Band Master</field>
        <field name="res_model">sfa.expense.band</field>
        <field name="view_mode">list,form</field>
        <!-- Use the list view ID here -->
        <!-- <field name="view_id" ref="view_sfa_expense_band_tree"/> -->
    </record>


    <record id="view_sfa_expense_type_list" model="ir.ui.view">
        <field name="name">sfa.expense.type.list</field>
        <field name="model">sfa.expense.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="rate_type"/>
                <field name="receipt_required" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_expense_type_form" model="ir.ui.view">
        <field name="name">sfa.expense.type.form</field>
        <field name="model">sfa.expense.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="rate_type"/>
                        <field name="receipt_required"/>
                        <field name="remarks_required"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sfa_expense_type" model="ir.actions.act_window">
        <field name="name">Expense Type Master</field>
        <field name="res_model">sfa.expense.type</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- Tier Label Configuration View -->
    <record id="action_sfa_city_tier_action" model="ir.actions.act_window">
        <field name="name">Cities &amp; Tiers</field>
        <field name="res_model">sfa.city.tier</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_sfa_city_tier_label" model="ir.actions.act_window">
        <field name="name">Configure Tier Labels</field>
        <field name="res_model">sfa.city.tier.label</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- City Tier Master View -->
    <record id="view_sfa_city_tier_list" model="ir.ui.view">
        <field name="name">sfa.city.tier.list</field>
        <field name="model">sfa.city.tier</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state_id"/>
                <field name="tier_label_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>


    <record id="view_sfa_travel_mode_list" model="ir.ui.view">
        <field name="name">sfa.travel.mode.list</field>
        <field name="model">sfa.travel.mode</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_travel_mode_form" model="ir.ui.view">
        <field name="name">sfa.travel.mode.form</field>
        <field name="model">sfa.travel.mode</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sfa_travel_mode" model="ir.actions.act_window">
        <field name="name">Travel Mode Master</field>
        <field name="res_model">sfa.travel.mode</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="view_sfa_expense_policy_list" model="ir.ui.view">
        <field name="name">sfa.expense.policy.list</field>
        <field name="model">sfa.expense.policy</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_expense_policy_form" model="ir.ui.view">
        <field name="name">sfa.expense.policy.form</field>
        <field name="model">sfa.expense.policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sfa_expense_policy" model="ir.actions.act_window">
        <field name="name">Expense Policy Master</field>
        <field name="res_model">sfa.expense.policy</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_sfa_expense_policy_form" model="ir.ui.view">
        <field name="name">sfa.expense.policy.form</field>
        <field name="model">sfa.expense.policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    
                    <!-- Added Policy Rule Lines under the main header -->
                    <notebook>
                        <page string="Policy Rule Lines">
                            <field name="rule_ids">
                                <list editable="bottom">
                                    <field name="band_id"/>
                                    <field name="expense_type_id"/>
                                    <field name="duty_type"/>
                                    <field name="city_tier_id"/>
                                    <field name="rate_type"/>
                                    <field name="rate"/>
                                    <field name="max_limit"/>
                                    <field name="auto_create" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

<!-- Adding to the existing Configuration menu -->
<menuitem id="menu_sfa_expense_band" 
          name="Band Master" 
          parent="hr_expense.menu_hr_expense_configuration" 
          action="action_sfa_expense_band" 
          sequence="50"/>

<menuitem id="menu_sfa_expense_type" 
          name="Expense Type Master" 
          parent="hr_expense.menu_hr_expense_configuration" 
          action="action_sfa_expense_type" 
          sequence="55"/>

<menuitem id="menu_sfa_city_tier_root" 
          name="City Tier Master" 
          parent="hr_expense.menu_hr_expense_configuration" 
          sequence="60"/>

<menuitem id="menu_sfa_city_tier_label" 
          name="Tier Labels" 
          parent="menu_sfa_city_tier_root" 
          action="action_sfa_city_tier_label" 
          sequence="1"/>

<menuitem id="menu_sfa_city_tier" 
          name="Cities &amp; Tiers" 
          parent="menu_sfa_city_tier_root" 
          action="action_sfa_city_tier_action" 
          sequence="2"/>

<menuitem id="menu_sfa_travel_mode" 
          name="Travel Mode Master" 
          parent="hr_expense.menu_hr_expense_configuration" 
          action="action_sfa_travel_mode" 
          sequence="65"/>

<menuitem id="menu_sfa_expense_policy" 
          name="Expense Policy Master" 
          parent="hr_expense.menu_hr_expense_root" 
          action="action_sfa_expense_policy" 
          sequence="70"/>
</odoo>