<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── UOM List View ──────────────────────────────────────────────── -->
    <record id="view_uom_list_emp360" model="ir.ui.view">
        <field name="name">uom.uom.list.emp360</field>
        <field name="model">uom.uom</field>
        <field name="arch" type="xml">
            <list string="Units of Measure">
                <field name="name"/>
                <field name="uom_type"/>
                <field name="factor" string="Ratio"/>
                <field name="rounding"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── UOM Form View ──────────────────────────────────────────────── -->
    <record id="view_uom_form_emp360" model="ir.ui.view">
        <field name="name">uom.uom.form.emp360</field>
        <field name="model">uom.uom</field>
        <field name="arch" type="xml">
            <form string="Unit of Measure">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Piece, Box, Dozen, Carton"/></h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="uom_type"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Accuracy">
                            <field name="factor"
                                   invisible="uom_type == 'reference'"
                                   string="How many in reference UOM"/>
                            <!-- <field name="factor_inv"
                                   invisible="uom_type != 'bigger'"
                                   string="Reference UOM per this UOM"/> -->
                            <field name="rounding"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── UOM Search View ────────────────────────────────────────────── -->
    <record id="view_uom_search_emp360" model="ir.ui.view">
        <field name="name">uom.uom.search.emp360</field>
        <field name="model">uom.uom</field>
        <field name="arch" type="xml">
            <search string="Search Units of Measure">
                <field name="name" string="UOM"/>
                <separator/>
                <filter string="Active"   name="active"   domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
                <!-- <group expand="1" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'uom_type'}"/>
                </group> -->
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────── -->
    <record id="action_uom_master_emp360" model="ir.actions.act_window">
        <field name="name">Units of Measure</field>
        <field name="res_model">uom.uom</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
        <field name="search_view_id" ref="view_uom_search_emp360"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create units of measure like Piece, Box, Dozen, Litre, Carton.
            </p>
        </field>
    </record>

</odoo>
