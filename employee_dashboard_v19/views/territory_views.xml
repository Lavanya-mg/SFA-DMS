<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ LIST ══════════════════════════════════════════════════════ -->
    <record id="view_fmcg_territory_list" model="ir.ui.view">
        <field name="name">fmcg.territory.list</field>
        <field name="model">fmcg.territory</field>
        <field name="arch" type="xml">
            <list string="Territories">
                <field name="name"/>
                <field name="code"/>
                <field name="region"/>
                <field name="account_count" string="Accounts"/>
                <field name="beat_count" string="Beats"/>
                <field name="employee_count" string="Employees"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ══ FORM ══════════════════════════════════════════════════════ -->
    <record id="view_fmcg_territory_form" model="ir.ui.view">
        <field name="name">fmcg.territory.form</field>
        <field name="model">fmcg.territory</field>
        <field name="arch" type="xml">
            <form string="Territory">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_accounts_emp360)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-building"
                                context="{'search_default_territory_id': id}">
                            <field name="account_count" widget="statinfo" string="Accounts"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-map-marker" disabled="1">
                            <field name="beat_count" widget="statinfo" string="Beats"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-users" disabled="1">
                            <field name="employee_count" widget="statinfo" string="Employees"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Territory Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="e.g. TER-NORTH"/>
                            <field name="region" placeholder="e.g. South India"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Add notes about this territory..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══ ACTION ════════════════════════════════════════════════════ -->
    <record id="action_fmcg_territory" model="ir.actions.act_window">
        <field name="name">Territories</field>
        <field name="res_model">fmcg.territory</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No territories yet.</p>
            <p>Create territories to organize your sales force by geography.</p>
        </field>
    </record>

</odoo>
