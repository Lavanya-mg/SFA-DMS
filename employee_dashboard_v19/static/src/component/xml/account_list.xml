<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="employee_dashboard_v19.FmcgAccountListView"
       t-inherit="web.ListView"
       t-inherit-mode="primary">
        <xpath expr="//Layout" position="before">
            <div class="d-flex align-items-center px-3 pt-2 pb-1" style="gap:8px;">
                <button class="btn btn-sm btn-light border d-flex align-items-center gap-1"
                        t-on-click="goBackToDashboard"
                        style="font-size:13px;">
                    <i class="fa fa-arrow-left"/>
                    Back to Dashboard
                </button>
            </div>
        </xpath>
    </t>

</templates>
