<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_emp360" model="ir.module.category">
            <field name="name">Employee 360</field>
            <field name="sequence">100</field>
        </record>

        <!-- v19: privilege links the category to the groups -->
        <record id="privilege_emp360" model="res.groups.privilege">
            <field name="name">Employee 360</field>
            <field name="category_id" ref="module_emp360"/>
            <field name="sequence">100</field>
        </record>

        <record id="group_employee_dashboard_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_emp360"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_employee_dashboard_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_emp360"/>
            <field name="implied_ids" eval="[(4, ref('group_employee_dashboard_user'))]"/>
        </record>
    </data>
</odoo>
