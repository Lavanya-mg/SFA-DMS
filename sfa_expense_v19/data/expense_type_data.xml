<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="expense_type_travel" model="sfa.expense.type">
        <field name="name">Travel &amp; Accommodation</field>
        <field name="code">TA</field>
        <field name="rate_type">actual</field>
        <field name="receipt_required" eval="True"/>
        <field name="remarks_required" eval="False"/>
        <field name="auto_create" eval="False"/>
        <field name="sequence">10</field>
    </record>

    <record id="expense_type_da" model="sfa.expense.type">
        <field name="name">Daily Allowance</field>
        <field name="code">DA</field>
        <field name="rate_type">per_day</field>
        <field name="receipt_required" eval="False"/>
        <field name="remarks_required" eval="False"/>
        <field name="auto_create" eval="True"/>
        <field name="sequence">20</field>
    </record>

    <record id="expense_type_mileage" model="sfa.expense.type">
        <field name="name">Mileage</field>
        <field name="code">MIL</field>
        <field name="rate_type">per_km</field>
        <field name="receipt_required" eval="False"/>
        <field name="remarks_required" eval="False"/>
        <field name="system_km_enabled" eval="True"/>
        <field name="auto_create" eval="False"/>
        <field name="sequence">30</field>
    </record>

    <record id="expense_type_food" model="sfa.expense.type">
        <field name="name">Meals</field>
        <field name="code">FOOD</field>
        <field name="rate_type">actual</field>
        <field name="receipt_required" eval="True"/>
        <field name="remarks_required" eval="False"/>
        <field name="auto_create" eval="False"/>
        <field name="sequence">40</field>
    </record>

    <record id="expense_type_comm" model="sfa.expense.type">
        <field name="name">Communication</field>
        <field name="code">COMM</field>
        <field name="rate_type">actual</field>
        <field name="receipt_required" eval="True"/>
        <field name="remarks_required" eval="False"/>
        <field name="auto_create" eval="False"/>
        <field name="sequence">50</field>
    </record>

    <record id="expense_type_gift" model="sfa.expense.type">
        <field name="name">Gifts</field>
        <field name="code">GIFT</field>
        <field name="rate_type">actual</field>
        <field name="receipt_required" eval="True"/>
        <field name="remarks_required" eval="True"/>
        <field name="auto_create" eval="False"/>
        <field name="sequence">60</field>
    </record>

    <record id="expense_type_general" model="sfa.expense.type">
        <field name="name">Expenses</field>
        <field name="code">EXP_GEN</field>
        <field name="rate_type">actual</field>
        <field name="receipt_required" eval="True"/>
        <field name="remarks_required" eval="False"/>
        <field name="auto_create" eval="False"/>
        <field name="sequence">70</field>
    </record>

</odoo>
