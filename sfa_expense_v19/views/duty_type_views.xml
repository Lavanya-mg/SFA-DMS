<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sfa_duty_type_list" model="ir.ui.view">
        <field name="name">sfa.duty.type.list</field>
        <field name="model">sfa.duty.type</field>
        <field name="arch" type="xml">
            <list string="Duty Types" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_duty_type_form" model="ir.ui.view">
        <field name="name">sfa.duty.type.form</field>
        <field name="model">sfa.duty.type</field>
        <field name="arch" type="xml">
            <form string="Duty Type">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

<record id="action_sfa_duty_type" model="ir.actions.act_window">
        <field name="name">Duty Types</field>
        <field name="res_model">sfa.duty.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
