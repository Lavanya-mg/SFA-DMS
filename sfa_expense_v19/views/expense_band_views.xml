<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sfa_expense_band_list" model="ir.ui.view">
        <field name="name">sfa.expense.band.list</field>
        <field name="model">sfa.expense.band</field>
        <field name="arch" type="xml">
            <list string="Band Master" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="grade"/>
                <field name="designation"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_expense_band_form" model="ir.ui.view">
        <field name="name">sfa.expense.band.form</field>
        <field name="model">sfa.expense.band</field>
        <field name="arch" type="xml">
            <form string="Band">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="grade"/>
                            <field name="designation"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sfa_expense_band" model="ir.actions.act_window">
        <field name="name">Band Master</field>
        <field name="res_model">sfa.expense.band</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
