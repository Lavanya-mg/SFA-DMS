<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sfa_expense_type_list" model="ir.ui.view">
        <field name="name">sfa.expense.type.list</field>
        <field name="model">sfa.expense.type</field>
        <field name="arch" type="xml">
            <list string="Expense Types" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="product_id" optional="show"/>
                <field name="rate_type"/>
                <field name="receipt_required"/>
                <field name="remarks_required"/>
                <field name="auto_create"/>
                <field name="system_km_enabled" optional="show"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_expense_type_form" model="ir.ui.view">
        <field name="name">sfa.expense.type.form</field>
        <field name="model">sfa.expense.type</field>
        <field name="arch" type="xml">
            <form string="Expense Type">
                <sheet>
                    <group>
                        <group string="Basic Info">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="product_id"/>
                            <field name="rate_type"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Behaviour">
                            <field name="receipt_required"/>
                            <field name="remarks_required"/>
                            <field name="auto_create"/>
                            <field name="system_km_enabled"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sfa_expense_type" model="ir.actions.act_window">
        <field name="name">Expense Types</field>
        <field name="res_model">sfa.expense.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
