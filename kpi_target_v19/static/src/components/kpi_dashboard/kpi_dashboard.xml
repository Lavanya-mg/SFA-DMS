<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="kpi_target_v19.KpiDashboard">
    <div class="kpi-dashboard o_action_manager"
         style="display:flex;flex-direction:column;flex:1;min-height:0;overflow-y:auto;padding:16px;">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <h2 class="mb-0" style="font-size:1.4rem;font-weight:700;color:#1f3050;">
                <i class="fa fa-bar-chart me-2 text-primary"/>KPI Target Dashboard
            </h2>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <div class="d-flex align-items-center gap-1">
                    <label class="mb-0 text-muted" style="font-size:13px;">Period:</label>
                    <select class="form-select form-select-sm" style="min-width:140px;"
                            t-on-change="onPeriodChange">
                        <option value="" t-att-selected="state.selectedPeriodId === null">All Periods</option>
                        <t t-foreach="state.periods" t-as="period" t-key="period.id">
                            <option t-att-value="period.id"
                                    t-att-selected="period.id === state.selectedPeriodId">
                                <t t-esc="period.name"/>
                            </option>
                        </t>
                    </select>
                </div>
                <button class="btn btn-sm btn-outline-secondary" t-on-click="() => this.loadData()">
                    <i class="fa fa-refresh"/> Refresh
                </button>
                <button class="btn btn-sm btn-primary" t-on-click="() => this.openCreateIndividualTarget()">
                    <i class="fa fa-plus"/> Individual Target
                </button>
                <button class="btn btn-sm btn-success" t-on-click="() => this.openCreateTeamTarget()">
                    <i class="fa fa-plus"/> Team Target
                </button>
            </div>
        </div>

        <!-- Loading -->
        <div t-if="state.loading" class="d-flex align-items-center justify-content-center"
             style="min-height:200px;">
            <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
            <span class="ms-2 text-muted">Loading KPI data…</span>
        </div>

        <div t-else="">

            <!-- Summary Cards -->
            <div class="row g-3 mb-3">
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center" style="border-left:4px solid #0d6efd!important;">
                        <div class="card-body py-3">
                            <div style="font-size:2rem;font-weight:700;color:#0d6efd;">
                                <t t-esc="state.summary.totalIndividual"/>
                            </div>
                            <div class="text-muted" style="font-size:12px;">Individual Targets</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center" style="border-left:4px solid #198754!important;">
                        <div class="card-body py-3">
                            <div style="font-size:2rem;font-weight:700;color:#198754;">
                                <t t-esc="state.summary.teamCount"/>
                            </div>
                            <div class="text-muted" style="font-size:12px;">Team Targets</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center" style="border-left:4px solid #fd7e14!important;">
                        <div class="card-body py-3">
                            <div style="font-size:2rem;font-weight:700;color:#fd7e14;">
                                <t t-esc="state.summary.avgAchievement"/>%
                            </div>
                            <div class="text-muted" style="font-size:12px;">Avg Achievement</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center" style="border-left:4px solid #6f42c1!important;">
                        <div class="card-body py-3">
                            <div style="font-size:2rem;font-weight:700;color:#6f42c1;">
                                <t t-esc="state.summary.achievedCount"/>/<t t-esc="state.summary.totalIndividual"/>
                            </div>
                            <div class="text-muted" style="font-size:12px;">Targets 100%+</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button t-att-class="'nav-link' + (state.activeTab === 'individual' ? ' active' : '')"
                            t-on-click="() => this.setTab('individual')">
                        <i class="fa fa-user me-1"/>Individual Targets
                        <span class="badge bg-secondary ms-1"><t t-esc="state.rows.length"/></span>
                    </button>
                </li>
                <li class="nav-item">
                    <button t-att-class="'nav-link' + (state.activeTab === 'team' ? ' active' : '')"
                            t-on-click="() => this.setTab('team')">
                        <i class="fa fa-users me-1"/>Team Targets
                        <span class="badge bg-secondary ms-1"><t t-esc="state.teamRows.length"/></span>
                    </button>
                </li>
            </ul>

            <!-- Individual Tab -->
            <div t-if="state.activeTab === 'individual'">
                <div t-if="state.rows.length === 0" class="text-center py-5">
                    <i class="fa fa-user-times fa-3x text-muted mb-3"/>
                    <p class="text-muted">No individual targets for selected period.</p>
                    <button class="btn btn-primary" t-on-click="() => this.openCreateIndividualTarget()">
                        <i class="fa fa-plus"/> Create Target
                    </button>
                </div>
                <div t-else="" class="table-responsive">
                    <div class="mb-2 text-muted" style="font-size:12px;">
                        <i class="fa fa-pencil text-primary"/> Click any target cell to edit inline
                    </div>
                    <table class="table table-bordered table-hover table-sm" style="font-size:13px;min-width:900px;">
                        <thead class="table-dark">
                            <tr>
                                <th rowspan="2">#</th>
                                <th rowspan="2">Employee</th>
                                <th rowspan="2">Status</th>
                                <th t-att-colspan="state.kpiTypes.length"
                                    class="text-center table-primary">Target
                                    <small class="d-block fw-normal text-primary-emphasis">(click to edit)</small>
                                </th>
                                <th t-att-colspan="state.kpiTypes.length"
                                    class="text-center table-success">Actual
                                    <small class="d-block fw-normal text-success-emphasis">(auto-computed)</small>
                                </th>
                                <th rowspan="2" class="text-center" style="min-width:120px;">Overall</th>
                                <th rowspan="2"></th>
                            </tr>
                            <tr>
                                <t t-foreach="state.kpiTypes" t-as="kpi" t-key="'h-t-' + kpi.key">
                                    <th class="text-center table-primary">
                                        <t t-esc="kpi.label"/>
                                    </th>
                                </t>
                                <t t-foreach="state.kpiTypes" t-as="kpi" t-key="'h-a-' + kpi.key">
                                    <th class="text-center table-success">
                                        <t t-esc="kpi.label"/>
                                    </th>
                                </t>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.rows" t-as="row" t-key="row.id">
                                <tr t-att-class="'kpi-row ' + getAchievementClass(row.achievements.overall)">
                                    <td class="text-muted text-center"><t t-esc="row_index + 1"/></td>
                                    <td>
                                        <strong><t t-esc="row.employee_name"/></strong>
                                        <span t-if="row.department"
                                              class="badge bg-light text-dark border ms-1"
                                              style="font-size:10px;">
                                            <t t-esc="row.department"/>
                                        </span>
                                    </td>
                                    <td>
                                        <span t-att-class="getStateBadgeClass(row.state)">
                                            <t t-esc="row.state"/>
                                        </span>
                                    </td>

                                    <!-- Target cells (editable) -->
                                    <t t-foreach="state.kpiTypes" t-as="kpi"
                                       t-key="'tc-' + row.id + kpi.key">
                                        <td class="text-center" style="cursor:pointer;background:#f0f4ff;"
                                            t-on-click="() => this.onCellClick(row.id, kpi.key)">
                                            <t t-if="isEditing(row.id, kpi.key)">
                                                <input type="number"
                                                       class="form-control form-control-sm text-center"
                                                       style="width:80px;margin:auto;"
                                                       t-model="state.editValue"
                                                       t-on-blur="onInputBlur"
                                                       t-on-keydown="onInputKeydown"/>
                                            </t>
                                            <t t-else="">
                                                <t t-esc="formatNumber(row.targets[kpi.key])"/>
                                                <i class="fa fa-pencil ms-1" style="color:#adb5bd;font-size:10px;"/>
                                            </t>
                                        </td>
                                    </t>

                                    <!-- Actual cells (read-only) -->
                                    <t t-foreach="state.kpiTypes" t-as="kpi"
                                       t-key="'ac-' + row.id + kpi.key">
                                        <td class="text-center" style="background:#f0fff4;">
                                            <t t-esc="formatNumber(row.actuals[kpi.key])"/>
                                            <span t-att-class="'ms-1 ' + getAchievementClass(row.achievements[kpi.key])"
                                                  style="font-size:10px;">
                                                (<t t-esc="formatPct(row.achievements[kpi.key])"/>)
                                            </span>
                                        </td>
                                    </t>

                                    <!-- Overall -->
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="flex-grow-1" style="height:8px;background:#e9ecef;border-radius:4px;overflow:hidden;">
                                                <div t-att-style="getProgressStyle(row.achievements.overall)"
                                                     style="height:100%;border-radius:4px;transition:width 0.3s;"/>
                                            </div>
                                            <span t-att-class="getAchievementClass(row.achievements.overall)"
                                                  style="font-size:12px;font-weight:600;white-space:nowrap;">
                                                <t t-esc="formatPct(row.achievements.overall)"/>
                                            </span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-xs btn-outline-primary"
                                                style="font-size:11px;padding:2px 8px;"
                                                t-on-click="() => this.openTargetForm(row.id)">
                                            <i class="fa fa-external-link"/>
                                        </button>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Team Tab -->
            <div t-if="state.activeTab === 'team'">
                <div t-if="state.teamRows.length === 0" class="text-center py-5">
                    <i class="fa fa-users fa-3x text-muted mb-3"/>
                    <p class="text-muted">No team targets for selected period.</p>
                    <button class="btn btn-success" t-on-click="() => this.openCreateTeamTarget()">
                        <i class="fa fa-plus"/> Create Team Target
                    </button>
                </div>
                <div t-else="" class="table-responsive">
                    <table class="table table-bordered table-hover table-sm" style="font-size:13px;min-width:900px;">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Manager</th>
                                <th>Period</th>
                                <th>Mode</th>
                                <th class="text-center">Members</th>
                                <th class="text-center">Status</th>
                                <th t-att-colspan="state.kpiTypes.length" class="text-center table-primary">Total Targets</th>
                                <th t-att-colspan="state.kpiTypes.length" class="text-center table-success">Team Actuals</th>
                                <th class="text-center" style="min-width:120px;">Achievement</th>
                                <th></th>
                            </tr>
                            <tr class="table-secondary">
                                <th colspan="6"/>
                                <t t-foreach="state.kpiTypes" t-as="kpi" t-key="'tth-t-' + kpi.key">
                                    <th class="text-center table-primary"><t t-esc="kpi.label"/></th>
                                </t>
                                <t t-foreach="state.kpiTypes" t-as="kpi" t-key="'tth-a-' + kpi.key">
                                    <th class="text-center table-success"><t t-esc="kpi.label"/></th>
                                </t>
                                <th/><th/>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.teamRows" t-as="trow" t-key="trow.id">
                                <tr>
                                    <td class="text-muted text-center"><t t-esc="trow_index + 1"/></td>
                                    <td><strong><t t-esc="trow.manager_name"/></strong>
                                        <span t-if="trow.department"
                                              class="badge bg-light text-dark border ms-1"
                                              style="font-size:10px;">
                                            <t t-esc="trow.department"/>
                                        </span>
                                    </td>
                                    <td><t t-esc="trow.period_name"/></td>
                                    <td>
                                        <span t-att-class="getModeBadgeClass(trow.assignment_mode)">
                                            <t t-if="trow.assignment_mode === 'distribute'">Distribute</t>
                                            <t t-else="">Individual</t>
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border">
                                            <t t-esc="trow.member_count"/>
                                        </span>
                                    </td>
                                    <td>
                                        <span t-att-class="getStateBadgeClass(trow.state)">
                                            <t t-esc="trow.state"/>
                                        </span>
                                    </td>
                                    <t t-foreach="state.kpiTypes" t-as="kpi" t-key="'ttc-' + trow.id + kpi.key">
                                        <td class="text-center" style="background:#f0f4ff;">
                                            <t t-esc="formatNumber(trow.total_targets[kpi.key])"/>
                                        </td>
                                    </t>
                                    <t t-foreach="state.kpiTypes" t-as="kpi" t-key="'tac-' + trow.id + kpi.key">
                                        <td class="text-center" style="background:#f0fff4;">
                                            <t t-esc="formatNumber(trow.team_actuals[kpi.key])"/>
                                        </td>
                                    </t>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="flex-grow-1" style="height:8px;background:#e9ecef;border-radius:4px;overflow:hidden;">
                                                <div t-att-style="getProgressStyle(trow.team_achievement)"
                                                     style="height:100%;border-radius:4px;"/>
                                            </div>
                                            <span t-att-class="getAchievementClass(trow.team_achievement)"
                                                  style="font-size:12px;font-weight:600;">
                                                <t t-esc="formatPct(trow.team_achievement)"/>
                                            </span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-xs btn-outline-success"
                                                style="font-size:11px;padding:2px 8px;"
                                                t-on-click="() => this.openTeamTargetForm(trow.id)">
                                            <i class="fa fa-external-link"/>
                                        </button>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</t>

</templates>
