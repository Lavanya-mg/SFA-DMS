<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ============================================================
     EMPLOYEE 360 — MOBILE SCHEMES SCREEN
     ============================================================ -->

<t t-name="employee_mobile_v19.MobileSchemes">

    <t t-if="state.loading">
        <div class="mobile360-loading">
            <div class="mobile360-spinner"/>
            <span class="mobile360-loading-text">Loading schemes...</span>
        </div>
    </t>

    <t t-else="">
        <!-- ── Hero Stats Header ──────────────────────────────── -->
        <div style="background:linear-gradient(135deg,#7209b7,#3a0ca3);padding:20px 16px 32px;position:relative;overflow:hidden;">
            <div class="mobile360-hero-decor"/>
            <div style="font-size:13px;color:rgba(255,255,255,0.8);font-weight:600;margin-bottom:14px;">
                <i class="fa fa-tags me-1"/> Schemes &amp; Promotions
            </div>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;">
                <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:10px 8px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:20px;font-weight:800;color:#fff;"><t t-esc="state.stats.active"/></div>
                    <div style="font-size:9px;color:rgba(255,255,255,0.7);font-weight:700;text-transform:uppercase;letter-spacing:0.3px;margin-top:2px;">Active</div>
                </div>
                <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:10px 8px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:20px;font-weight:800;color:#fff;"><t t-esc="state.stats.draft"/></div>
                    <div style="font-size:9px;color:rgba(255,255,255,0.7);font-weight:700;text-transform:uppercase;letter-spacing:0.3px;margin-top:2px;">Draft</div>
                </div>
                <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:10px 8px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:20px;font-weight:800;color:#fff;"><t t-esc="state.stats.expired"/></div>
                    <div style="font-size:9px;color:rgba(255,255,255,0.7);font-weight:700;text-transform:uppercase;letter-spacing:0.3px;margin-top:2px;">Expired</div>
                </div>
                <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:10px 8px;border:1px solid rgba(255,255,255,0.2);text-align:center;">
                    <div style="font-size:20px;font-weight:800;color:#fff;"><t t-esc="state.stats.total"/></div>
                    <div style="font-size:9px;color:rgba(255,255,255,0.7);font-weight:700;text-transform:uppercase;letter-spacing:0.3px;margin-top:2px;">Total</div>
                </div>
            </div>
        </div>

        <div style="padding:0 16px;margin-top:-14px;">

            <!-- Search -->
            <div class="mobile360-search-bar">
                <i class="fa fa-search mobile360-search-icon"/>
                <input class="mobile360-search-input" type="text" placeholder="Search scheme name or code..."
                    t-on-input="onSearchInput"/>
            </div>

            <!-- Status Filter Chips -->
            <div class="mobile360-chips">
                <t t-foreach="[['active','Active'],['draft','Draft'],['expired','Expired'],['all','All']]" t-as="f" t-key="f[0]">
                    <button t-attf-class="mobile360-chip {{state.statusFilter === f[0] ? 'active' : ''}}"
                        t-on-click="() => this.setStatusFilter(f[0])"><t t-esc="f[1]"/></button>
                </t>
            </div>

            <!-- Benefit Type Chips -->
            <div class="mobile360-chips" style="margin-bottom:14px;">
                <t t-foreach="[['all','All'],['free_product','Free Product'],['percent_discount','% Disc'],['price_discount','Price Disc'],['points','Points']]" t-as="b" t-key="b[0]">
                    <button t-attf-class="mobile360-chip {{state.benefitFilter === b[0] ? 'active' : ''}}"
                        t-on-click="() => this.setBenefitFilter(b[0])"><t t-esc="b[1]"/></button>
                </t>
            </div>

            <!-- Empty state -->
            <t t-if="!state.filtered.length">
                <div class="mobile360-empty" style="padding:48px 16px;">
                    <div class="mobile360-empty-icon"><i class="fa fa-tags"/></div>
                    <div class="mobile360-empty-title">No Schemes Found</div>
                    <div class="mobile360-empty-sub">Try changing the status or benefit filter</div>
                </div>
            </t>

            <!-- Scheme Cards -->
            <t t-foreach="state.filtered" t-as="scheme" t-key="scheme.id">
                <div class="mobile360-order-card" t-on-click="() => this.openDetail(scheme)"
                    style="margin-bottom:12px;border-radius:16px;overflow:hidden;">

                    <!-- Colored left accent strip + icon -->
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                        <div t-attf-style="width:40px;height:40px;border-radius:12px;background:{{benefitGradient(scheme.benefit_type)}};display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;flex-shrink:0;">
                            <i t-attf-class="fa {{benefitIcon(scheme.benefit_type)}}"/>
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:14px;font-weight:700;color:#0f172a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                <t t-esc="scheme.name"/>
                            </div>
                            <div style="font-size:11px;color:#64748b;margin-top:2px;">
                                <t t-esc="scheme.scheme_code"/>
                                <span style="margin:0 6px;color:#cbd5e1;">·</span>
                                <t t-esc="schemeTypeLabel(scheme.scheme_type)"/>
                            </div>
                        </div>
                        <div style="flex-shrink:0;text-align:right;">
                            <span t-attf-class="mobile360-badge {{stateClass(scheme.state)}}" style="margin-bottom:4px;display:inline-block;">
                                <t t-esc="stateLabel(scheme.state)"/>
                            </span>
                        </div>
                    </div>

                    <!-- Benefit summary -->
                    <div style="margin-top:10px;padding:8px 10px;background:#f8fafc;border-radius:10px;border:1px solid #e2e8f0;">
                        <div style="font-size:12px;color:#7209b7;font-weight:700;">
                            <i t-attf-class="fa {{benefitIcon(scheme.benefit_type)}} me-1"/>
                            <t t-esc="scheme.benefit_summary or benefitTypeLabel(scheme.benefit_type)"/>
                        </div>
                        <t t-if="scheme.min_invoice_value">
                            <div style="font-size:11px;color:#64748b;margin-top:3px;">
                                Min Invoice: ₹<t t-esc="scheme.min_invoice_value.toLocaleString('en-IN')"/>
                            </div>
                        </t>
                    </div>

                    <!-- Date range + product lines count -->
                    <div style="display:flex;justify-content:space-between;margin-top:10px;">
                        <span style="font-size:11px;color:#94a3b8;">
                            <i class="fa fa-calendar-o me-1"/>
                            <t t-esc="fmtDate(scheme.date_from)"/> – <t t-esc="fmtDate(scheme.date_to)"/>
                        </span>
                        <t t-if="scheme.line_count">
                            <span style="font-size:11px;color:#94a3b8;">
                                <i class="fa fa-list me-1"/><t t-esc="scheme.line_count"/> product(s)
                            </span>
                        </t>
                    </div>
                </div>
            </t>

            <!-- Bottom padding for nav bar -->
            <div style="height:16px;"/>
        </div>

        <!-- ── Scheme Detail Bottom Sheet ─────────────────────── -->
        <t t-if="state.showDetail and state.selected">
            <div class="mobile360-overlay" t-on-click.self="closeDetail">
                <div class="mobile360-sheet" style="max-height:88vh;">
                    <div class="mobile360-sheet-handle"/>
                    <div class="mobile360-sheet-header">
                        <span class="mobile360-sheet-title"><t t-esc="state.selected.name"/></span>
                        <button class="mobile360-sheet-close" t-on-click="closeDetail"><i class="fa fa-times"/></button>
                    </div>

                    <div class="mobile360-sheet-body" style="padding:0;">
                        <!-- Gradient header -->
                        <div t-attf-style="background:{{benefitGradient(state.selected.benefit_type)}};padding:16px 20px;color:#fff;">
                            <div style="font-size:12px;opacity:0.8;"><t t-esc="state.selected.scheme_code"/></div>
                            <div style="font-size:20px;font-weight:800;margin-top:4px;">
                                <t t-esc="state.selected.benefit_summary or benefitTypeLabel(state.selected.benefit_type)"/>
                            </div>
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:12px;">
                                <span style="font-size:13px;opacity:0.85;">
                                    <i class="fa fa-calendar-o me-1"/>
                                    <t t-esc="fmtDate(state.selected.date_from)"/> – <t t-esc="fmtDate(state.selected.date_to)"/>
                                </span>
                                <span t-attf-class="mobile360-badge {{stateClass(state.selected.state)}}"
                                    style="background:rgba(255,255,255,0.25);color:#fff;border:1px solid rgba(255,255,255,0.3);">
                                    <t t-esc="stateLabel(state.selected.state)"/>
                                </span>
                            </div>
                        </div>

                        <!-- Detail rows -->
                        <div style="padding:16px 20px;">
                            <!-- Scheme type -->
                            <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #e2e8f0;">
                                <span style="font-size:12px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;">Scheme Type</span>
                                <span style="font-size:13px;font-weight:700;color:#0f172a;"><t t-esc="schemeTypeLabel(state.selected.scheme_type)"/></span>
                            </div>
                            <!-- Benefit type -->
                            <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #e2e8f0;">
                                <span style="font-size:12px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;">Benefit Type</span>
                                <span style="font-size:13px;font-weight:700;color:#0f172a;"><t t-esc="benefitTypeLabel(state.selected.benefit_type)"/></span>
                            </div>
                            <!-- Min invoice -->
                            <t t-if="state.selected.min_invoice_value">
                                <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #e2e8f0;">
                                    <span style="font-size:12px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;">Min Invoice Value</span>
                                    <span style="font-size:13px;font-weight:700;color:#0f172a;">₹<t t-esc="state.selected.min_invoice_value.toLocaleString('en-IN')"/></span>
                                </div>
                            </t>
                            <!-- Product lines -->
                            <t t-if="state.selected.line_count">
                                <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #e2e8f0;">
                                    <span style="font-size:12px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;">Product Lines</span>
                                    <span style="font-size:13px;font-weight:700;color:#0f172a;"><t t-esc="state.selected.line_count"/> product(s)</span>
                                </div>
                            </t>
                            <!-- Notes / T&C -->
                            <t t-if="state.selected.notes">
                                <div style="margin-top:14px;">
                                    <div style="font-size:12px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:0.3px;margin-bottom:6px;">Terms &amp; Conditions</div>
                                    <div style="font-size:13px;color:#334155;line-height:1.6;background:#f8fafc;border-radius:10px;padding:12px;border:1px solid #e2e8f0;">
                                        <t t-esc="state.selected.notes"/>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </t>
</t>

</templates>
