<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="sfa_incentive.IncentiveDashboard">
    <div class="sfa-incentive-dashboard">

        <!-- ── Header ── -->
        <div class="sfa-inc-header">
            <h2><i class="fa fa-trophy" style="color:#7c3aed;margin-right:10px;"/>Incentive Dashboard</h2>
            <div class="sfa-inc-actions">
                <button class="btn btn-outline-secondary btn-sm" t-on-click="openAnnualBonus"
                        t-att-disabled="state.calculating ? 'disabled' : false">
                    <i class="fa fa-calendar"/> Annual Bonus
                </button>
                <button class="btn btn-primary btn-sm" t-on-click="runCalculation"
                        t-att-disabled="state.calculating ? 'disabled' : false">
                    <i t-if="!state.calculating" class="fa fa-play-circle"/>
                    <i t-else="" class="fa fa-spinner fa-spin"/>
                    Run Calculation
                </button>
            </div>
        </div>

        <!-- ── Filter bar ── -->
        <div class="sfa-inc-filters-bar">
            <!-- Period -->
            <div class="sfa-filter-group">
                <label class="sfa-filter-label">Period</label>
                <select class="sfa-filter-select" t-on-change="onPeriodChange">
                    <option value="">-- All --</option>
                    <t t-foreach="state.periods" t-as="p" t-key="p.id">
                        <option t-att-value="p.id"
                                t-att-selected="p.id === state.periodId ? 'selected' : false">
                            <t t-esc="p.name"/>
                        </option>
                    </t>
                </select>
            </div>

            <!-- Target Criteria -->
            <div class="sfa-filter-group">
                <label class="sfa-filter-label">Target Criteria</label>
                <select class="sfa-filter-select" t-on-change="onCriteriaChange">
                    <option value="">-- All --</option>
                    <t t-foreach="state.filterOptions.criteria" t-as="c" t-key="c.id">
                        <option t-att-value="c.id"
                                t-att-selected="c.id === state.criteriaId ? 'selected' : false">
                            <t t-esc="c.name"/>
                        </option>
                    </t>
                </select>
            </div>

            <!-- Profile -->
            <div class="sfa-filter-group">
                <label class="sfa-filter-label">Profile</label>
                <select class="sfa-filter-select" t-on-change="onProfileChange">
                    <option value="">-- All --</option>
                    <t t-foreach="state.filterOptions.profiles" t-as="p" t-key="p.id">
                        <option t-att-value="p.id"
                                t-att-selected="p.id === state.profileId ? 'selected' : false">
                            <t t-esc="p.name"/>
                        </option>
                    </t>
                </select>
            </div>

            <!-- Territory -->
            <div class="sfa-filter-group">
                <label class="sfa-filter-label">Territory</label>
                <select class="sfa-filter-select" t-on-change="onTerritoryChange">
                    <option value="">-- All --</option>
                    <t t-foreach="state.filterOptions.territories" t-as="tr" t-key="tr.id">
                        <option t-att-value="tr.id"
                                t-att-selected="tr.id === state.territoryId ? 'selected' : false">
                            <t t-esc="tr.name"/>
                        </option>
                    </t>
                </select>
            </div>
        </div>

        <!-- ── Status tabs with counts ── -->
        <div class="sfa-inc-tabs">
            <t t-foreach="state.tabs" t-as="tab" t-key="tab.key">
                <button class="sfa-inc-tab"
                        t-att-class="state.activeTab === tab.key ? 'active' : ''"
                        t-on-click="() => this.setTab(tab.key)">
                    <t t-esc="tab.label"/>
                    <span class="sfa-tab-count"
                          t-att-class="state.activeTab === tab.key ? 'active' : ''">
                        <t t-esc="tabCounts[tab.key] or 0"/>
                    </span>
                </button>
            </t>
        </div>

        <!-- ── Stat boxes ── -->
        <div class="sfa-inc-stats">
            <div class="sfa-inc-stat-box orange">
                <div class="stat-label">Calculated</div>
                <div class="stat-amount" t-esc="formatAmount(state.stats.calculated.amount)"/>
                <div class="stat-count"><t t-esc="state.stats.calculated.count"/> records</div>
            </div>
            <div class="sfa-inc-stat-box yellow">
                <div class="stat-label">Pending Approval</div>
                <div class="stat-amount" t-esc="formatAmount(state.stats.pending_approval.amount)"/>
                <div class="stat-count"><t t-esc="state.stats.pending_approval.count"/> records</div>
            </div>
            <div class="sfa-inc-stat-box green">
                <div class="stat-label">Approved</div>
                <div class="stat-amount" t-esc="formatAmount(state.stats.approved.amount)"/>
                <div class="stat-count"><t t-esc="state.stats.approved.count"/> records</div>
            </div>
            <div class="sfa-inc-stat-box purple">
                <div class="stat-label">Paid</div>
                <div class="stat-amount" t-esc="formatAmount(state.stats.paid.amount)"/>
                <div class="stat-count"><t t-esc="state.stats.paid.count"/> records</div>
            </div>
        </div>

        <!-- ── Records table ── -->
        <div class="sfa-inc-table-wrap">
            <t t-if="state.loading">
                <div class="sfa-empty-state">
                    <i class="fa fa-spinner fa-spin" style="font-size:1.5rem;"/>
                    <div class="mt-2">Loading…</div>
                </div>
            </t>
            <t t-elif="filteredRecords.length === 0">
                <div class="sfa-empty-state">
                    <i class="fa fa-trophy" style="font-size:2rem;opacity:.2;"/>
                    <div style="margin-top:8px;font-weight:600;">No Incentive Records</div>
                    <div style="font-size:.85rem;color:#9ca3af;">No records found for the selected period and filters.</div>
                </div>
            </t>
            <t t-else="">
                <table class="sfa-inc-table">
                    <thead>
                        <tr>
                            <th><input type="checkbox"/></th>
                            <th>Salesperson</th>
                            <th>Criteria</th>
                            <th>Achievement %</th>
                            <th>Slab</th>
                            <th>Calculated</th>
                            <th>Final</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="filteredRecords" t-as="rec" t-key="rec.id">
                            <tr>
                                <td><input type="checkbox"/></td>
                                <td style="font-weight:500;color:#111827;"><t t-esc="rec.employee"/></td>
                                <td>
                                    <span class="inc-criteria-badge"
                                          t-att-class="rec.criteria === 'Revenue' ? 'blue' : rec.criteria === 'Collection' ? 'green' : rec.criteria === 'New Outlets' ? 'yellow' : rec.criteria === 'Productive Calls' ? 'purple' : 'gray'">
                                        <t t-esc="rec.criteria or '—'"/>
                                    </span>
                                </td>
                                <td t-att-class="rec.achievement_percent >= 100 ? 'text-success fw-bold' : rec.achievement_percent >= 80 ? 'text-warning fw-bold' : 'text-danger fw-bold'">
                                    <t t-esc="rec.achievement_percent.toFixed(2)"/>%
                                </td>
                                <td style="color:#374151;"><t t-esc="rec.slab or '—'"/></td>
                                <td style="text-align:right;"><t t-esc="formatAmount(rec.calculated_amount)"/></td>
                                <td style="text-align:right;font-weight:600;"><t t-esc="formatAmount(rec.final_amount)"/></td>
                                <td>
                                    <span class="inc-badge" t-att-class="rec.status">
                                        <t t-esc="statusLabel(rec.status)"/>
                                    </span>
                                </td>
                                <td>
                                    <t t-if="rec.status === 'calculated'">
                                        <button class="btn btn-xs btn-outline-primary"
                                                t-on-click="() => this.submitForApproval(rec.id)"
                                                title="Submit for Approval">
                                            <i class="fa fa-paper-plane"/>
                                        </button>
                                    </t>
                                    <t t-if="rec.status === 'pending_approval'">
                                        <button class="btn btn-xs btn-outline-success me-1"
                                                t-on-click="() => this.approveRecord(rec.id)"
                                                title="Approve">
                                            <i class="fa fa-check"/>
                                        </button>
                                        <button class="btn btn-xs btn-outline-danger"
                                                t-on-click="() => this.rejectRecord(rec.id)"
                                                title="Reject">
                                            <i class="fa fa-times"/>
                                        </button>
                                    </t>
                                    <t t-if="rec.status === 'approved'">
                                        <button class="btn btn-xs btn-outline-secondary"
                                                t-on-click="() => this.markPaid(rec.id)"
                                                title="Mark as Paid">
                                            <i class="fa fa-money"/>
                                        </button>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>
        </div>

        <!-- Toast -->
        <t t-if="state.toast">
            <div class="sfa-toast" t-att-class="state.toast.type">
                <t t-esc="state.toast.message"/>
            </div>
        </t>
    </div>
</t>

</templates>
