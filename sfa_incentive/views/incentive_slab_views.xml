<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_sfa_incentive_slab_list" model="ir.ui.view">
        <field name="name">sfa.incentive.slab.list</field>
        <field name="model">sfa.incentive.slab</field>
        <field name="arch" type="xml">
            <list string="Incentive Slabs" decoration-muted="not active">
                <field name="name" string="Slab Name"/>
                <field name="criteria_id" string="Criteria"/>
                <field name="profile_id" string="Profile"/>
                <field name="territory_id" string="Territory"/>
                <field name="range_display" string="Range"/>
                <field name="payout_display" string="Payout"/>
                <field name="multiplier" string="Multiplier"/>
                <field name="active" string="Status"
                       widget="toggle_button"
                       options='{"terminology": {"string_true": "Active", "string_false": "Inactive", "classname_true": "text-success", "classname_false": "text-danger"}}'/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sfa_incentive_slab_form" model="ir.ui.view">
        <field name="name">sfa.incentive.slab.form</field>
        <field name="model">sfa.incentive.slab</field>
        <field name="arch" type="xml">
            <form string="Incentive Slab">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Slab Name…"/>
                        </h1>
                    </div>
                    <group string="Slab Details">
                        <group>
                            <field name="criteria_id"
                                   placeholder="Leave empty for Universal"
                                   options="{'no_create': True}"/>
                            <field name="profile_id"
                                   placeholder="Leave empty for Universal"
                                   options="{'no_create': True}"/>
                            <field name="territory_id"
                                   placeholder="Leave empty for Universal"
                                   options="{'no_create': True}"/>
                            <field name="min_achievement"/>
                            <field name="max_achievement"/>
                        </group>
                        <group>
                            <field name="payout_type"/>
                            <field name="payout_value" string="Payout Value"/>
                            <field name="multiplier"/>
                            <field name="sort_order"/>
                            <field name="date_from" string="Effective From"/>
                            <field name="date_to" string="Effective To"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Standard list/form action (kept for internal use) -->
    <record id="action_sfa_incentive_slab" model="ir.actions.act_window">
        <field name="name">Incentive Slabs</field>
        <field name="res_model">sfa.incentive.slab</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <!-- Slab Manager Client Action (OWL dashboard) -->
    <record id="action_sfa_slab_manager" model="ir.actions.client">
        <field name="name">Slab Manager</field>
        <field name="tag">sfa_slab_manager</field>
    </record>
</odoo>
