<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_incentive_profile" model="ir.ui.view">
        <field name="name">hr.employee.form.incentive.profile</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="profile_id" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
