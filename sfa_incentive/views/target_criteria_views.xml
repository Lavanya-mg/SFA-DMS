<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sfa_target_criteria_list" model="ir.ui.view">
        <field name="name">sfa.target.criteria.list</field>
        <field name="model">sfa.target.criteria</field>
        <field name="arch" type="xml">
            <list string="Target Criteria">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="target_field"/>
                <field name="actual_field"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_target_criteria_form" model="ir.ui.view">
        <field name="name">sfa.target.criteria.form</field>
        <field name="model">sfa.target.criteria</field>
        <field name="arch" type="xml">
            <form string="Target Criteria">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="target_field"/>
                        <field name="actual_field"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sfa_target_criteria" model="ir.actions.act_window">
        <field name="name">Target Criteria</field>
        <field name="res_model">sfa.target.criteria</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Target Criteria Manager (OWL client action, Salesforce-style) -->
    <record id="action_sfa_target_criteria_manager" model="ir.actions.client">
        <field name="name">Target Criteria Manager</field>
        <field name="tag">sfa_target_criteria_manager</field>
    </record>
</odoo>
