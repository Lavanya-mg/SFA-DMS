<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sfa_incentive_profile_list" model="ir.ui.view">
        <field name="name">sfa.incentive.profile.list</field>
        <field name="model">sfa.incentive.profile</field>
        <field name="arch" type="xml">
            <list string="Incentive Profiles">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sfa_incentive_profile_form" model="ir.ui.view">
        <field name="name">sfa.incentive.profile.form</field>
        <field name="model">sfa.incentive.profile</field>
        <field name="arch" type="xml">
            <form string="Incentive Profile">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sfa_incentive_profile" model="ir.actions.act_window">
        <field name="name">Incentive Profiles</field>
        <field name="res_model">sfa.incentive.profile</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
